exec sed -i \{s/tb_sunrise_opamp_ac_ss_res_bcs_vdda_min_n40.raw/tb_sunrise_opamp_ac_sf_res_bcs_vdda_min_n40.raw/\} $spicefile
exec sed -i \{s/CMRR_DC_dB_ss_res_bcs_vdda_min_n40.txt/CMRR_DC_dB_sf_res_bcs_vdda_min_n40.txt/\} $spicefile
exec sed -i \{s/vout_v_ss_res_bcs_vdda_min_n40.txt/vout_v_sf_res_bcs_vdda_min_n40.txt/\} $spicefile
exec sed -i \{s/iddahv_uA_ss_res_bcs_vdda_min_n40.txt/iddahv_uA_sf_res_bcs_vdda_min_n40.txt/\} $spicefile
simulate
