*.lib /home/slice/pdk/iHP/IHP-Open-PDK/ihp-sg13g2/libs.tech/ngspice/models/cornerRES.lib res_typ_mismatch
*.lib /home/slice/pdk/iHP/IHP-Open-PDK/ihp-sg13g2/libs.tech/ngspice/models/cornerRES.lib res_bcs_mismatch
*.lib /home/slice/pdk/iHP/IHP-Open-PDK/ihp-sg13g2/libs.tech/ngspice/models/cornerRES.lib res_wcs_mismatch


* Parameters
.param xvdda_hv = 3.3
.csparam xvdda_hv_var = 'xvdda_hv'
.param xvdda_lv = 1.5
.csparam xvdda_lv_var = 'xvdda_lv'
.param cor_id = 0
.csparam cor_id_var = 'cor_id'
.param dec_code_var = 1
.csparam xdec_code_var = 'dec_code_var'
.param xvdda = 3.3
.param xvcm = 3.3/2 
.param xvnbias = 760m
.param xvncasc = 1.184
.param xvpcasc = 2.035
.param xnoise_on = 1
.param xvinp = 10m
.param xvload = 0.7
.param xR1var = 100k
.param xR2var = 50k
.param xRz = 2273
.param xtsim = 1u
.csparam xtsim_var = 'xtsim'
.param xAv = 5
.csparam xAv_var = 'xAv'
.param xstep_en = 1 
.param xint_bias_en = 0
* active lo => 0 = pd
.param xpdb = 1
.param xibias = 5u
.param xCl = 25p
.param xCc = 80p
.param xCz = 3.2p*0
.param xstep = 10m
.param xtstep = 10n
.csparam xtstep_var = 'xtstep'
.param xtrf = 20p
.param xvos = 0m
.param xgmdp = 1m
.param xAv0_dB = 60
.param xGBW = 1Meg

.temp 27

* vlogA instantiation
.model OTA_vcvs OTA_vcvs
.model dec2bin_10b dec2bin_10b
.model ideal_sw ideal_sw
  
.include tb_sunrise_bias_nia_top_CMR_OS.save
  
*.save all

.save v(vout) i(vvdda_hv_opamp)
  
.control

pre_osdi OTA_vcvs.osdi
pre_osdi dec2bin_10b.osdi
pre_osdi ideal_sw.osdi

set xTj = ( 27 )
let xTj_var  = $xTj
set temp = $xTj 

   let run = 1

  dowhile run <= 1
  reset
   
** 1. DCOP ANALYSIS ** 
  
  op 
  remzerovec
  set filetype=binary
  ** first write deletes existing file
  *comment out when running across MC
  write tb_sunrise_opamp_dcop.raw
 
** 2. TRAN ANALYSIS ** 

  remzerovec
  *set appendwrite
  tran $&xtstep_var $&xtsim_var
  *comment out when running across MC
  write tb_sunrise_opamp_tran.raw
  *unset appendwrite 
 
** 3. TRAN MEASURES ** 
 
  * 3.0 Global parameters:   
  echo cor_id = \\"$&cor_id_var\\"
  *comment out when running across MC
  echo \\"$&cor_id_var\\" > vout_v.txt
  echo \\"$&cor_id_var\\" > iddahv_uA.txt
  echo --
  echo temp = \\"$&xTj_var\\"
  *comment out when running across MC
  echo \\"$&xTj_var\\" >> vout_v.txt
  echo \\"$&xTj_var\\" >> iddahv_uA.txt
  echo --  
  echo vdda_hv = \\"$&xvdda_hv_var\\"
  *comment out when running across MC
  echo \\"$&xvdda_hv_var\\" >> vout_v.txt
  echo \\"$&xvdda_hv_var\\" >> iddahv_uA.txt
  echo --
  echo vdda_lv = \\"$&xvdda_lv_var\\"
  *comment out when running across MC
  echo \\"$&xvdda_lv_var\\" >> vout_v.txt
  echo \\"$&xvdda_lv_var\\" >> iddahv_uA.txt
  echo -- 
 
  echo --
  meas tran vout_ave AVG v(vout) from=100n to=$&xtsim_var
  meas tran iddahv_ave AVG i(vvdda_hv_opamp) from=100n to=$&xtsim_var
  let iddahv_ave_uA = iddahv_ave*(-1e6)
  echo --
  echo  vout_V = \\"$&vout_ave\\"
  *comment out when running across MC
  echo  iddahv_A = \\"$&iddahv_ave\\"
  print iddahv_ave_uA
  echo \\"$&vout_ave\\" >> vout_v.txt
  echo \\"$&iddahv_ave_uA\\" >> iddahv_uA.txt
  echo --
 
** 4. AC ANALYSIS ** 
 
  ac dec 10 1 1G
  
  *remzerovec 
  *write tb_sunrise_ina_ac.raw
  
** 5. CMR MEASURES ** 

  * 5.0 Global parameters:   
  echo cor_id = \\"$&cor_id_var\\"
  echo \\"$&cor_id_var\\" > CMRR_DC_dB.txt
  echo --
  echo temp = \\"$&xTj_var\\"
  echo \\"$&xTj_var\\" >> CMRR_DC_dB.txt
  echo --  
  echo vdda_hv = \\"$&xvdda_hv_var\\"
  echo \\"$&xvdda_hv_var\\" >> CMRR_DC_dB.txt
  echo --
  echo vdda_lv = \\"$&xvdda_lv_var\\"
  echo \\"$&xvdda_lv_var\\" >> CMRR_DC_dB.txt
  echo -- 
  
  * 5.1 CMRR:    
  meas AC CMRR_DC_dB FIND vdb(vout) AT=1
  echo --
  echo  CMRR_DC_dB = \\"$&CMRR_DC_dB\\"
  echo \\"$&CMRR_DC_dB\\" >> CMRR_DC_dB.txt
  echo --
  
  remzerovec
  set filetype=binary
  ** first write deletes existing file
  *comment out when running across MC
  write tb_sunrise_opamp_ac.raw
  *typically comment out
  *write tb_sunrise_ina_ac_mc.raw
  ** set appendwrite appends following writes to existing raw file
  set appendwrite
  let run = run+1
  end
 
  setplot
*quit 0
.endc


"}
