C {devices/launcher.sym} -740 -60 0 0 {# Temp corner sweep for Tmin = -40C, Tmax = 125C, Trt = 27C
# Assumes stim file has set temp to 27C
name=h4
descr="Temp corner group (step/stb)"
tclcommand="
set spicefile $netlist_dir/tb_sunrise_opamp_nia_STEP_STB_NOISE.spice
xschem netlist
simulate
after 1000 ;# wait 1sec for ngspice to start and read netlist
# set T = 125C
exec sed -i \{/^\\.param cor_id/s/0/1/\} $spicefile
exec sed -i \{s/set xTj = ( 27 )/set xTj = ( 125 )/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_tran.raw/tb_sunrise_opamp_tran_Tmax.raw/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_ac1.raw/tb_sunrise_opamp_ac1_Tmax.raw/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_ac2.raw/tb_sunrise_opamp_ac2_Tmax.raw/\} $spicefile
exec sed -i \{s/ac_measures.txt/ac_measures_Tmax.txt/\} $spicefile
simulate
after 1000 ;# wait 1sec for ngspice to start and read netlist
# set T = -40C
exec sed -i \{/^\\.param cor_id/s/1/2/\} $spicefile
exec sed -i \{s/set xTj = ( 125 )/set xTj = ( -40 )/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_tran_Tmax.raw/tb_sunrise_opamp_tran_Tmin.raw/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_ac1_Tmax.raw/tb_sunrise_opamp_ac1_Tmin.raw/\} $spicefile
exec sed -i \{s/tb_sunrise_opamp_ac2_Tmax.raw/tb_sunrise_opamp_ac2_Tmin.raw/\} $spicefile
exec sed -i \{s/ac_measures_Tmax.txt/ac_measures_Tmin.txt/\} $spicefile
simulate
"
}
C {devices/launcher.sym} -740 -140 0 0 {# Process corner sweep for tt, ff, ss, sf, fs
# Assumes stim file has set corner to tt
name=h5
descr="Process corner group (step/stb)"
tclcommand="
set spicefile $netlist_dir/tb_sunrise_opamp_nia_STEP_STB_NOISE.spice
xschem netlist
simulate
after 1000 ;# wait 1sec for ngspice to start and read netlist
# change to ff corner
exec sed -i \{/^\\.param cor_id/s/0/1/\} $spicefile
# use below if you want to change both MOShv and MOSlv corners simultaneously
#exec sed -i \{/^\\.lib/s/tt/ff/\} $spicefile
